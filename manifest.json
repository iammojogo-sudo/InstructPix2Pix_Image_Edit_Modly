{
  "id": "instructpix2pix_edit",
  "name": "InstructPix2Pix Edit",
  "type": "model",
  "source": "https://github.com/iammojogo-sudo/InstructPix2Pix_Image_Edit_Modly",
  "description": "Instruction-based image editing with InstructPix2Pix. Provide an image and a text instruction (e.g. 'make it a oil painting', 'turn the dog into a cat') and get an edited image back. Fits 4-6GB VRAM.",
  "version": "1.0.0",
  "author": "iammojogo",
  "vram_gb": 4,
  "tags": [
    "image-to-image",
    "image-editing",
    "instructpix2pix",
    "i2i"
  ],
  "nodes": [
    {
      "id": "edit",
      "name": "Edit Image",
      "input": "image",
      "inputs": ["image"],
      "output": "image",
      "hf_repo": "timbrooks/instruct-pix2pix",
      "download_check": "model_index.json",
      "params_schema": [
        {
          "id": "prompt",
          "label": "Edit Instruction",
          "type": "string",
          "default": "",
          "tooltip": "Describe the edit you want (e.g. 'make it night time')"
        },
        {
          "id": "steps",
          "label": "Steps",
          "type": "int",
          "default": 30,
          "min": 10,
          "max": 100
        },
        {
          "id": "guidance_scale",
          "label": "Guidance Scale",
          "type": "float",
          "default": 7.5,
          "min": 1,
          "max": 20,
          "tooltip": "How strongly to follow the instruction"
        },
        {
          "id": "image_guidance_scale",
          "label": "Image Guidance",
          "type": "float",
          "default": 1.5,
          "min": 0.5,
          "max": 5.0,
          "tooltip": "How much to preserve the original image"
        },
        {
          "id": "num_images",
          "label": "Number of Outputs",
          "type": "int",
          "default": 1,
          "min": 1,
          "max": 4
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": 0,
          "min": 0,
          "max": 4294967295
        }
      ]
    }
  ],
  "generator_class": "InstructPix2PixGenerator"
}
